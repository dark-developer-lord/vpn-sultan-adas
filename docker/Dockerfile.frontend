# Production Angular UI with Material Design
FROM nginx:alpine

# Copy Angular build artifacts (all files from dist)
COPY frontend/dist/vpn-dashboard/* /usr/share/nginx/html/

# Copy nginx config with SPA routing support
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Expose port
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
