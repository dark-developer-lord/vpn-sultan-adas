FROM alpine:latest

RUN apk add --no-cache \
    postgresql-client \
    ca-certificates \
    curl

# Mock API server for development/testing
RUN echo '#!/bin/sh' > /usr/local/bin/vpn-api && \
    echo 'echo "{\"status\":\"ok\"}"' >> /usr/local/bin/vpn-api && \
    chmod +x /usr/local/bin/vpn-api

EXPOSE 3000

CMD ["vpn-api"]
